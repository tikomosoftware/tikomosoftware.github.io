include "lib/picture.prism"
flame(k, t)  <-
  rise <- frac(t * 0.6 + k * 0.07)
  Circle{ x: 55 * cos(k * 0.9) * (1 - rise * 0.5), y: 55 * sin(k * 0.9) * 0.4 - 40 + rise * 150,
  r: 14 * (1 - rise) + 4, h: 40 - rise * 40, a: (1 - rise) * 0.5, fill: 1 }
frame(t) : Picture  <-  pic( concat( [ Circle{x: 0, y: 0 - 20, r: 40, h: 40, a: 0.3, fill: 1} ], times(30, k -> flame(k, t)) ) )
main : () !console  <-  show!console "press Animate for a fighting aura"
