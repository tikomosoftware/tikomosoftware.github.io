-- Interactive :: a rose whose petal count is a slider. In the playground, drag it to morph
-- between roses; from the CLI, `slider(default, min, max)` just uses the default (5).
include "lib/draw2d.prism"
picture  <-  polyline(t -> V{ x: 140 * cos(slider(5, 2, 12) * t * 0.05) * cos(t * 0.05),
                              y: 140 * cos(slider(5, 2, 12) * t * 0.05) * sin(t * 0.05) }, 0, 252)
main : () !console  <-  show!console "in the playground, drag the slider to change the petals"
