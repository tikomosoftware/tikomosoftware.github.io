-- Eye candy :: a Maurer rose, n = 7, d = 19.
include "lib/draw2d.prism"
picture  <-  polyline(i -> V{ x: 140 * sin(7 * i * 19 * 0.01745) * cos(i * 19 * 0.01745),
                              y: 140 * sin(7 * i * 19 * 0.01745) * sin(i * 19 * 0.01745) }, 0, 360)
main : () !console  <-  show!console "press Draw to see a Maurer rose (n=7, d=19)"
