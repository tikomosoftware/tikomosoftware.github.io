-- Eye candy :: another Maurer rose, n = 2, d = 39 -- a completely different lattice from
-- physics/maurer.prism. Tiny changes to (n, d) give wildly different patterns.

include "lib/draw2d.prism"

picture  <-  polyline(i -> V{ x: 140 * sin(2 * i * 39 * 0.01745) * cos(i * 39 * 0.01745),
                              y: 140 * sin(2 * i * 39 * 0.01745) * sin(i * 39 * 0.01745) }, 0, 360)

main : () !console  <-  show!console "press Draw to see another Maurer rose"
