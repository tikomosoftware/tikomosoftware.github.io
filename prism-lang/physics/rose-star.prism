-- Eye candy :: rose r = cos(2.5 theta) -> a 5-pointed star rose (closes after two turns).
include "lib/draw2d.prism"
picture  <-  polyline(t -> V{ x: 140 * cos(2.5 * t * 0.05) * cos(t * 0.05),
                              y: 140 * cos(2.5 * t * 0.05) * sin(t * 0.05) }, 0, 252)
main : () !console  <-  show!console "press Draw to see a star rose"
