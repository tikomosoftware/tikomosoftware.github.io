-- Eye candy :: a 5-cusped hypocycloid (R/r = 5): x = 4cos t + cos 4t, y = 4sin t - sin 4t.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 30 * (4 * cos(t * 0.05) + cos(4 * t * 0.05)),
                              y: 30 * (4 * sin(t * 0.05) - sin(4 * t * 0.05)) }, 0, 130)

main : () !console  <-  show!console "press Draw to see a 5-cusped hypocycloid"
