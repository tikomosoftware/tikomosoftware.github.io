-- Eye candy :: an epicycloid -- the curve traced by a point on a small circle (radius r)
-- rolling around the outside of a big one (radius R). With R/r = 5 it has 5 cusps.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 50 * cos(t * 0.05) - 10 * cos(5 * t * 0.05),
                              y: 50 * sin(t * 0.05) - 10 * sin(5 * t * 0.05) }, 0, 130)

main : () !console  <-  show!console "press Draw to see an epicycloid"
