-- Eye candy :: a 7-cusped epicycloid: x = 8cos t - cos 8t, y = 8sin t - sin 8t.
include "lib/draw2d.prism"
picture  <-  polyline(t -> V{ x: 16 * (8 * cos(t * 0.05) - cos(8 * t * 0.05)),
                              y: 16 * (8 * sin(t * 0.05) - sin(8 * t * 0.05)) }, 0, 130)
main : () !console  <-  show!console "press Draw to see a 7-cusped epicycloid"
