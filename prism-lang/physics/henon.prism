-- Strange attractor :: the Henon map, x' = 1 - a x^2 + y, y' = b x (a = 1.4, b = 0.3).
-- The orbit settles onto a banana-shaped curve with fractal cross-section.

trace(n, x, y, acc)  <-
  n match
    0  =>  acc
    _  =>
      nx  <-  1 - 1.4 * x * x + y
      ny  <-  0.3 * x
      [ Dot{x: nx * 180, y: ny * 180}, ..trace(n - 1, nx, ny, acc) ]

picture  <-  trace(1200, 0, 0, [])

main : () !console  <-  show!console "press Draw to see the Henon attractor"
