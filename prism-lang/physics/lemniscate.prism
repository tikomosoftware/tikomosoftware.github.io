-- Eye candy :: a lemniscate of Bernoulli (a figure eight), in the parametric form
-- x = a cos t / (1 + sin^2 t),  y = a sin t cos t / (1 + sin^2 t).

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 200 * cos(t * 0.05) / (1 + sin(t * 0.05) * sin(t * 0.05)),
                              y: 200 * sin(t * 0.05) * cos(t * 0.05) / (1 + sin(t * 0.05) * sin(t * 0.05)) }, 0, 130)

main : () !console  <-  show!console "press Draw to see a lemniscate (figure eight)"
