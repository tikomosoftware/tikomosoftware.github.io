-- Eye candy :: a rose r = cos(7 theta). Odd coefficient -> 7 petals, closing in half a turn.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 140 * cos(7 * t * 0.05) * cos(t * 0.05),
                              y: 140 * cos(7 * t * 0.05) * sin(t * 0.05) }, 0, 64)

main : () !console  <-  show!console "press Draw to see a 7-petal rose"
