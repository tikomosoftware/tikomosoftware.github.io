include "lib/picture.prism"
hash(i)  <-  frac(sin(i * 12.9898 + 7.0) * 43758.5453)
arc(k, t)  <-
  seed <- floor(t * 10) * 8 + k
  a <- k / 10 * 6.2832
  ja <- a + (hash(seed) - 0.5) * 0.6
  Line{ x1: 48 * cos(a), y1: 48 * sin(a), x2: (80 + hash(seed) * 40) * cos(ja), y2: (80 + hash(seed) * 40) * sin(ja), h: 200, a: 0.8 }
frame(t) : Picture  <-  pic( concat( [ Circle{x: 0, y: 0, r: 46, h: 200, a: 0.5, fill: 1} ], times(10, k -> arc(k, t)) ) )
main : () !console  <-  show!console "press Animate for an electric aura"
