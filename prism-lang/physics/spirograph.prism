-- Eye candy :: a spirograph (hypotrochoid). A pen offset `d` on a wheel of radius r
-- rolling inside a ring R traces looping rosettes; the 2:3 ratio closes after 3 turns.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 25 * (2 * cos(t * 0.05) + 5 * cos(t * 0.05 * 0.6667)),
                              y: 25 * (2 * sin(t * 0.05) - 5 * sin(t * 0.05 * 0.6667)) }, 0, 380)

main : () !console  <-  show!console "press Draw to see a spirograph"
