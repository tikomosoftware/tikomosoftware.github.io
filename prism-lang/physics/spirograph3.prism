-- Eye candy :: a spirograph (hypotrochoid) at a 5:2 ratio -- a dense star rosette.
include "lib/draw2d.prism"
picture  <-  polyline(t -> V{ x: 20 * (5 * cos(t * 0.05) + 5 * cos(t * 0.05 * 2.5)),
                              y: 20 * (5 * sin(t * 0.05) - 5 * sin(t * 0.05 * 2.5)) }, 0, 252)
main : () !console  <-  show!console "press Draw to see a 5:2 spirograph"
