-- Eye candy :: the classic heart curve.
-- x = 16 sin^3 t,  y = 13 cos t - 5 cos 2t - 2 cos 3t - cos 4t.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 8 * (16 * sin(t * 0.05) * sin(t * 0.05) * sin(t * 0.05)),
                              y: 8 * (13 * cos(t * 0.05) - 5 * cos(2 * t * 0.05)
                                      - 2 * cos(3 * t * 0.05) - cos(4 * t * 0.05)) }, 0, 130)

main : () !console  <-  show!console "press Draw to see a heart"
