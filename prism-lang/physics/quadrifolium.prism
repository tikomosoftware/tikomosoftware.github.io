-- Eye candy :: a quadrifolium, the four-petal rose r = cos(2 theta).

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 130 * cos(2 * t * 0.05) * cos(t * 0.05),
                              y: 130 * cos(2 * t * 0.05) * sin(t * 0.05) }, 0, 130)

main : () !console  <-  show!console "press Draw to see a quadrifolium"
