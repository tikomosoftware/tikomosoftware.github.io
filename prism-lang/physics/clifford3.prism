-- Strange attractor :: Clifford with (a,b,c,d) = -1.8, -2.0, -0.5, -0.9.
trace(n, x, y, acc)  <-
  n match
    0  =>  acc
    _  =>
      nx  <-  sin(0 - 1.8 * y) + (0 - 0.5) * cos(0 - 1.8 * x)
      ny  <-  sin(0 - 2.0 * x) + (0 - 0.9) * cos(0 - 2.0 * y)
      [ Dot{x: nx * 120, y: ny * 120}, ..trace(n - 1, nx, ny, acc) ]
picture  <-  trace(1400, 0, 0, [])
main : () !console  <-  show!console "press Draw to see a third Clifford attractor"
