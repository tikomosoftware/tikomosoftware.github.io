-- Eye candy :: a Maurer rose with n = 5, d = 97 -- yet another lattice.

include "lib/draw2d.prism"

picture  <-  polyline(i -> V{ x: 140 * sin(5 * i * 97 * 0.01745) * cos(i * 97 * 0.01745),
                              y: 140 * sin(5 * i * 97 * 0.01745) * sin(i * 97 * 0.01745) }, 0, 360)

main : () !console  <-  show!console "press Draw to see a Maurer rose (n=5, d=97)"
