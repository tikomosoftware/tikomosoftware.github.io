-- Eye candy :: an epitrochoid -- a point offset on a wheel rolling around the OUTSIDE of
-- a ring: x = (R+r)cos t - d cos((R+r)/r t),  y = (R+r)sin t - d sin((R+r)/r t).

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 18 * (8 * cos(t * 0.05) - 5 * cos(4 * t * 0.05)),
                              y: 18 * (8 * sin(t * 0.05) - 5 * sin(4 * t * 0.05)) }, 0, 130)

main : () !console  <-  show!console "press Draw to see an epitrochoid"
