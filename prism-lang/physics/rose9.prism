-- Eye candy :: rose r = cos(9 theta) -> 9 petals.
include "lib/draw2d.prism"
picture  <-  polyline(t -> V{ x: 140 * cos(9 * t * 0.05) * cos(t * 0.05),
                              y: 140 * cos(9 * t * 0.05) * sin(t * 0.05) }, 0, 64)
main : () !console  <-  show!console "press Draw to see a 9-petal rose"
