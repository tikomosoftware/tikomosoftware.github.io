-- Eye candy :: a 5-petal rose, r = cos(5 theta). With an ODD coefficient the curve closes
-- in half a turn and draws exactly k petals.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 140 * cos(5 * t * 0.05) * cos(t * 0.05),
                              y: 140 * cos(5 * t * 0.05) * sin(t * 0.05) }, 0, 64)

main : () !console  <-  show!console "press Draw to see a 5-petal rose"
