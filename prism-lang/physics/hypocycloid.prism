-- Eye candy :: an astroid -- the 4-cusped star traced by a point on a small circle
-- rolling inside a big one. Parametric form: x = a cos^3 t, y = a sin^3 t.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 140 * cos(t * 0.05) * cos(t * 0.05) * cos(t * 0.05),
                              y: 140 * sin(t * 0.05) * sin(t * 0.05) * sin(t * 0.05) }, 0, 130)

main : () !console  <-  show!console "press Draw to see an astroid"
