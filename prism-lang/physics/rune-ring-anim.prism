include "lib/picture.prism"
glyph(i, t)  <-
  gx <- 110 * cos(i / 10 * 6.2832 + t * 0.4)
  gy <- 110 * sin(i / 10 * 6.2832 + t * 0.4)
  Poly{ pts: [ Pt{x: gx - 8, y: gy - 8}, Pt{x: gx + 8, y: gy - 8}, Pt{x: gx, y: gy + 8}, Pt{x: gx - 8, y: gy - 8} ], h: 50, a: 0.6 + 0.4 * sin(t * 3 + i), fill: 1 }
frame(t) : Picture  <-
  pic( concat( [ Circle{x: 0, y: 0, r: 120, h: 50, a: 0.5}, Circle{x: 0, y: 0, r: 100, h: 50, a: 0.4} ], times(10, i -> glyph(i, t)) ) )
main : () !console  <-  show!console "press Animate for a rune ring"
