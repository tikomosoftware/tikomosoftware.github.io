-- Eye candy :: a limacon with an inner loop, r = a + b cos theta with b > a.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: (40 + 90 * cos(t * 0.05)) * cos(t * 0.05),
                              y: (40 + 90 * cos(t * 0.05)) * sin(t * 0.05) }, 0, 130)

main : () !console  <-  show!console "press Draw to see a limacon"
