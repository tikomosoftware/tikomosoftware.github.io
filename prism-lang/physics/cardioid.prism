-- Eye candy :: a cardioid, the heart-shaped curve r = a(1 + cos theta), drawn in polar.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 80 * (1 + cos(t * 0.05)) * cos(t * 0.05),
                              y: 80 * (1 + cos(t * 0.05)) * sin(t * 0.05) }, 0, 130)

main : () !console  <-  show!console "press Draw to see a cardioid"
