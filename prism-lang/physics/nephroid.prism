-- Eye candy :: a nephroid (2-cusped epicycloid): x = 3cos t - cos 3t, y = 3sin t - sin 3t.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 42 * (3 * cos(t * 0.05) - cos(3 * t * 0.05)),
                              y: 42 * (3 * sin(t * 0.05) - sin(3 * t * 0.05)) }, 0, 130)

main : () !console  <-  show!console "press Draw to see a nephroid"
