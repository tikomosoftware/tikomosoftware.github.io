-- Eye candy :: a gear. The radius jumps between two values as we go around (a square
-- wave on a circle) -- note the `if` expression used right inside the point function.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: (95 + 18 * (if sin(9 * t * 0.05) > 0 then 1 else 0 - 1)) * cos(t * 0.05),
                              y: (95 + 18 * (if sin(9 * t * 0.05) > 0 then 1 else 0 - 1)) * sin(t * 0.05) }, 0, 130)

main : () !console  <-  show!console "press Draw to see a gear"
