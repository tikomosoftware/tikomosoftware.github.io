-- Strange attractor :: the Svensson attractor.
--   x' = d sin(a x) - sin(b y),  y' = c cos(a x) + cos(b y).   (a,b,c,d = 1.5,-1.8,1.6,0.9)

trace(n, x, y, acc)  <-
  n match
    0  =>  acc
    _  =>
      nx  <-  0.9 * sin(1.5 * x) - sin(0 - 1.8 * y)
      ny  <-  1.6 * cos(1.5 * x) + cos(0 - 1.8 * y)
      [ Dot{x: nx * 90, y: ny * 90}, ..trace(n - 1, nx, ny, acc) ]

picture  <-  trace(1500, 0.1, 0.1, [])

main : () !console  <-  show!console "press Draw to see a Svensson attractor"
