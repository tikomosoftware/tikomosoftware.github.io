-- Eye candy :: a polar rose, r = cos(k*theta). With k = 4 the curve has 8 petals.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 130 * cos(4 * t * 0.05) * cos(t * 0.05),
                              y: 130 * cos(4 * t * 0.05) * sin(t * 0.05) }, 0, 130)

main : () !console  <-  show!console "press Draw to see a rose curve"
