-- Eye candy :: a cycloid -- the arching path traced by a point on the rim of a wheel
-- rolling along the ground: x = r(t - sin t), y = r(1 - cos t). Three arches.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 30 * (t * 0.1 - sin(t * 0.1)),
                              y: 30 * (1 - cos(t * 0.1)) }, 0, 190)

main : () !console  <-  show!console "press Draw to see a cycloid"
