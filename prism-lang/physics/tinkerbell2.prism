-- Strange attractor :: Tinkerbell with (a,b,c,d) = 0.9, -0.6013, 2.0, 0.27.
trace(n, x, y, acc)  <-
  n match
    0  =>  acc
    _  =>
      nx  <-  x * x - y * y + 0.9 * x - 0.6013 * y
      ny  <-  2 * x * y + 2 * x + 0.27 * y
      [ Dot{x: nx * 130, y: ny * 130}, ..trace(n - 1, nx, ny, acc) ]
picture  <-  trace(1400, 0 - 0.72, 0 - 0.64, [])
main : () !console  <-  show!console "press Draw to see another Tinkerbell attractor"
