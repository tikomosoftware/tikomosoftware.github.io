-- Eye candy :: a spirograph at a 3:4 ratio -- a fuller rosette than the 2:3 one.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 18 * (3 * cos(t * 0.05) + 6 * cos(t * 0.05 * 0.75)),
                              y: 18 * (3 * sin(t * 0.05) - 6 * sin(t * 0.05 * 0.75)) }, 0, 510)

main : () !console  <-  show!console "press Draw to see a 3:4 spirograph"
