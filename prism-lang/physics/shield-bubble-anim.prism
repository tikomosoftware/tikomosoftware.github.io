include "lib/picture.prism"
hexPt(i, t)  <-
  r <- 110 + 6 * sin(t * 3 + i)
  Pt{ x: r * cos(i / 6 * 6.2832 + 0.5), y: r * sin(i / 6 * 6.2832 + 0.5) }
frame(t) : Picture  <-
  pic([ Poly{pts: times(7, i -> hexPt(i, t)), h: 200, a: 0.35 + 0.3 * abs(sin(t * 2)), fill: 1},
  Poly{pts: times(7, i -> hexPt(i, t)), h: 200} ])
main : () !console  <-  show!console "press Animate for a shield bubble"
