-- Eye candy :: a Lissajous figure at a 5:4 frequency ratio (a denser weave than the 3:2).

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 150 * sin(t * 0.04 * 5),
                              y: 150 * sin(t * 0.04 * 4 + 1) }, 0, 320)

main : () !console  <-  show!console "press Draw to see a 5:4 Lissajous figure"
