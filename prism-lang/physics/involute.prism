-- Eye candy :: the involute of a circle, the curve a taut string traces as it unwinds:
--   x = R(cos t + t sin t),  y = R(sin t - t cos t).

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 7 * (cos(t * 0.1) + t * 0.1 * sin(t * 0.1)),
                              y: 7 * (sin(t * 0.1) - t * 0.1 * cos(t * 0.1)) }, 0, 200)

main : () !console  <-  show!console "press Draw to see an involute of a circle"
