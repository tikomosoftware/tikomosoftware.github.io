-- Eye candy :: a dimpled limacon, r = a + b cos theta with a > b (no inner loop, a dimple).
include "lib/draw2d.prism"
picture  <-  polyline(t -> V{ x: (90 + 45 * cos(t * 0.05)) * cos(t * 0.05),
                              y: (90 + 45 * cos(t * 0.05)) * sin(t * 0.05) }, 0, 130)
main : () !console  <-  show!console "press Draw to see a dimpled limacon"
