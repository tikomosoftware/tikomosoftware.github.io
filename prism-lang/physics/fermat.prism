-- Eye candy :: a Fermat spiral, r = a * sqrt(theta) -- the whorl seen in seed heads.

include "lib/draw2d.prism"

picture  <-  polyline(t -> V{ x: 9 * sqrt(t * 0.1) * cos(t * 0.1),
                              y: 9 * sqrt(t * 0.1) * sin(t * 0.1) }, 0, 250)

main : () !console  <-  show!console "press Draw to see a Fermat spiral"
