-- Eye candy :: a 7-cusped hypocycloid: x = 6cos t + cos 6t, y = 6sin t - sin 6t.
include "lib/draw2d.prism"
picture  <-  polyline(t -> V{ x: 18 * (6 * cos(t * 0.05) + cos(6 * t * 0.05)),
                              y: 18 * (6 * sin(t * 0.05) - sin(6 * t * 0.05)) }, 0, 130)
main : () !console  <-  show!console "press Draw to see a 7-cusped hypocycloid"
