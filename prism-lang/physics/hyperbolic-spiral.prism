-- The hyperbolic (reciprocal) spiral: r = a / theta. It approaches a straight asymptote far
-- out and winds tighter and tighter near the pole.
include "lib/picture.prism"
n  <-  300
pt(i)  <-
  th  <-  0.5 + i / n * 22.0
  r   <-  110 / th
  Pt{ x: r * cos(th), y: r * sin(th) }
picture  <-  [ Poly{ pts: times(n + 1, i -> pt(i)), h: 40 } ]
main : () !console  <-  show!console "press Draw to see a hyperbolic spiral"
