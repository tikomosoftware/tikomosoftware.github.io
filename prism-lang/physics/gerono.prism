-- Eye candy :: the lemniscate of Gerono (a figure eight), x = cos t, y = sin t cos t.
include "lib/draw2d.prism"
picture  <-  polyline(t -> V{ x: 150 * cos(t * 0.05),
                              y: 150 * sin(t * 0.05) * cos(t * 0.05) }, 0, 130)
main : () !console  <-  show!console "press Draw to see a Gerono lemniscate"
